rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Only the owner can read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Study Spots ────────────────────────────────────────────────────────
    match /studySpots/{spotId} {
      // Anyone logged in can read spots
      allow read: if request.auth != null;

      // Any logged-in user can create a spot
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;

      // Only the creator can update/delete their spot
      // (rating updates are done via Cloud Functions in production)
      allow update: if request.auth != null;
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    // ── Reviews ────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      // Anyone logged in can read reviews
      allow read: if request.auth != null;

      // Logged-in users can create reviews with their own userId
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.overallRating >= 1
        && request.resource.data.overallRating <= 5;

      // Only the author can edit or delete their review
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}
